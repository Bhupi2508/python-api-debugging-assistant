# Phase 2 AI configuration
# Copy this file to: .env

# Select provider (default should be cloud; Ollama is optional)
# Examples:
# AI_PROVIDER=openai
# AI_PROVIDER=gemini
# AI_PROVIDER=claude
# AI_PROVIDER=ollama
AI_PROVIDER=openai

# Common
REQUEST_TIMEOUT=60

# Model (provider-specific env vars are also supported)
# For OpenAI/Gemini/Claude you can set:
# OPENAI_MODEL / GEMINI_MODEL / CLAUDE_MODEL
# (These map into config.model)
OPENAI_MODEL=gpt-4o-mini

# --- OpenAI ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# Optional:
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Gemini ---
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GEMINI_MODEL=gemini-1.5-flash

# --- Claude ---
# CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY
# CLAUDE_MODEL=claude-3-5-sonnet-20240620

# --- Ollama (optional/local) ---
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

